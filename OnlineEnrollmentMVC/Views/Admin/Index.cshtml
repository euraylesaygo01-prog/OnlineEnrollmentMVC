@model List<OnlineEnrollmentMVC.Models.Student>
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = null;
    var courses = ViewBag.Courses as List<OnlineEnrollmentMVC.Models.Course> ?? new List<OnlineEnrollmentMVC.Models.Course>();
    var payments = ViewBag.Payments as List<OnlineEnrollmentMVC.Models.Payment> ?? new List<OnlineEnrollmentMVC.Models.Payment>();
    int totalStudents = Model.Count;
    int enrolledCount = Model.Count(s => s.Status == "Enrolled");
    int pendingCount = Model.Count(s => s.Status == "Pending");
    int paidCount = payments.Count(p => p.Status == "Paid");
    int unpaidCount = payments.Count(p => p.Status == "Unpaid");
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Online Enrollment - Admin</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #0a0e2e 0%, #1a1f4e 50%, #0d1537 100%);
            font-family: 'Segoe UI', sans-serif;
        }
        .top-bar {
            display: flex; justify-content: space-between; align-items: center;
            padding: 16px 32px;
            background: rgba(255,255,255,0.05);
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .top-left { display: flex; align-items: center; gap: 10px; }
        .logo-icon { font-size: 24px; }
        .logo-text { color: #fff; font-size: 18px; font-weight: 700; }
        .admin-badge {
            padding: 3px 10px;
            background: rgba(167,139,250,0.15);
            border: 1px solid rgba(167,139,250,0.3);
            border-radius: 20px; color: #a78bfa; font-size: 11px; font-weight: 600;
        }
        .btn-logout {
            padding: 8px 16px;
            background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2);
            border-radius: 8px; color: #fca5a5; font-size: 13px; text-decoration: none;
        }
        .content { padding: 32px; }
        .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 16px; margin-bottom: 32px; }
        .stat-card {
            background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
            border-radius: 14px; padding: 20px 24px;
        }
        .stat-label { color: rgba(255,255,255,0.4); font-size: 12px; margin-bottom: 8px; }
        .stat-value { color: #fff; font-size: 28px; font-weight: 700; }
        .stat-sub { color: rgba(255,255,255,0.3); font-size: 12px; margin-top: 4px; }
        .tabs { display: flex; gap: 4px; margin-bottom: 28px; border-bottom: 1px solid rgba(255,255,255,0.08); }
        .tab-btn {
            padding: 10px 22px; background: transparent; border: none;
            border-bottom: 2px solid transparent; color: rgba(255,255,255,0.4);
            font-size: 14px; font-weight: 500; cursor: pointer; margin-bottom: -1px;
        }
        .tab-btn.active { color: #4f8ef7; border-bottom-color: #4f8ef7; }
        .tab-btn:hover:not(.active) { color: rgba(255,255,255,0.7); }
        .tab-panel { display: none; }
        .tab-panel.active { display: block; }
        .table-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
        .table-header h3 { color: #fff; font-size: 17px; font-weight: 700; }
        .data-table {
            width: 100%; border-collapse: collapse;
            background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);
            border-radius: 14px; overflow: hidden;
        }
        .data-table thead tr { background: rgba(255,255,255,0.06); }
        .data-table th {
            padding: 13px 18px; text-align: left; color: rgba(255,255,255,0.4);
            font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px;
        }
        .data-table td {
            padding: 14px 18px; color: rgba(255,255,255,0.8);
            font-size: 13px; border-top: 1px solid rgba(255,255,255,0.05);
        }
        .data-table tr:hover td { background: rgba(255,255,255,0.02); }
        .badge { padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
        .badge-pending { background: rgba(251,191,36,0.15); color: #fbbf24; }
        .badge-enrolled { background: rgba(34,197,94,0.15); color: #4ade80; }
        .badge-rejected { background: rgba(239,68,68,0.15); color: #fca5a5; }
        .badge-paid { background: rgba(34,197,94,0.15); color: #4ade80; }
        .badge-unpaid { background: rgba(251,191,36,0.15); color: #fbbf24; }
        .badge-active { background: rgba(34,197,94,0.12); color: #4ade80; }
        .badge-inactive { background: rgba(239,68,68,0.12); color: #fca5a5; }
        .btn-sm { padding: 5px 12px; border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer; border: none; text-decoration: none; display: inline-block; }
        .btn-approve { background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.3); color: #4ade80; }
        .btn-reject { background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; }
        .btn-delete { background: rgba(239,68,68,0.3); border: 1px solid rgba(239,68,68,0.6); color: #ff4444; font-weight: 700; }
        .btn-paid { background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.3); color: #4ade80; }
        .btn-view { background: rgba(79,142,247,0.15); border: 1px solid rgba(79,142,247,0.3); color: #4f8ef7; }
        .btn-edit { background: rgba(167,139,250,0.15); border: 1px solid rgba(167,139,250,0.3); color: #a78bfa; }
        .btn-toggle-on { background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.25); color: #fca5a5; }
        .btn-toggle-off { background: rgba(34,197,94,0.12); border: 1px solid rgba(34,197,94,0.25); color: #4ade80; }
        .btn-primary {
            padding: 9px 18px; background: linear-gradient(135deg, #4f8ef7, #2563eb);
            border: none; border-radius: 8px; color: #fff; font-size: 13px; font-weight: 600; cursor: pointer;
        }
        .already-paid { color: rgba(255,255,255,0.25); font-size: 12px; font-style: italic; }
        .modal-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,0.7); z-index: 100; align-items: center; justify-content: center;
        }
        .modal-overlay.open { display: flex; }
        .modal-box {
            background: #151a3e; border: 1px solid rgba(255,255,255,0.12);
            border-radius: 20px; padding: 32px; width: 440px;
        }
        .modal-box h3 { color: #fff; font-size: 18px; font-weight: 700; margin-bottom: 24px; }
        .form-group { margin-bottom: 16px; }
        .form-group label { display: block; color: rgba(255,255,255,0.6); font-size: 12px; margin-bottom: 6px; font-weight: 600; }
        .form-input {
            width: 100%; padding: 10px 14px;
            background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
            border-radius: 8px; color: #fff; font-size: 14px; outline: none;
        }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        .modal-actions { display: flex; gap: 10px; margin-top: 24px; justify-content: flex-end; }
        .btn-cancel {
            padding: 9px 18px; background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.12); border-radius: 8px;
            color: rgba(255,255,255,0.6); font-size: 13px; cursor: pointer;
        }
        .no-data { text-align: center; padding: 40px; color: rgba(255,255,255,0.3); font-size: 14px; }
        .action-cell { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }
    </style>
</head>
<body>
    <div class="top-bar">
        <div class="top-left">
            <span class="logo-icon">🎓</span>
            <span class="logo-text">Online Enrollment</span>
            <span class="admin-badge">ADMIN</span>
        </div>
        <a href="/Account/Logout" class="btn-logout">Logout</a>
    </div>

    <div class="content">
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-label">Total Students</div>
                <div class="stat-value">@totalStudents</div>
                <div class="stat-sub">registered</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Enrolled</div>
                <div class="stat-value">@enrolledCount</div>
                <div class="stat-sub">approved</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Pending</div>
                <div class="stat-value">@pendingCount</div>
                <div class="stat-sub">awaiting review</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Payments Paid</div>
                <div class="stat-value">@paidCount</div>
                <div class="stat-sub">@unpaidCount unpaid</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Active Courses</div>
                <div class="stat-value">@courses.Count(c => c.IsActive)</div>
                <div class="stat-sub">programs open</div>
            </div>
        </div>

        <div class="tabs">
            <button class="tab-btn active" onclick="switchTab('students', this)">👨‍🎓 Students</button>
            <button class="tab-btn" onclick="switchTab('payments', this)">💳 Payments</button>
            <button class="tab-btn" onclick="switchTab('courses', this)">📚 Courses</button>
        </div>

        <!-- STUDENTS TAB -->
        <div id="tab-students" class="tab-panel active">
            <div class="table-header"><h3>All Students</h3></div>
            @if (!Model.Any())
            {
                <div class="no-data">No students registered yet.</div>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Student</th><th>Student No.</th><th>Program</th>
                            <th>Registered</th><th>Status</th><th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight:600;color:#fff">@s.FirstName @s.LastName</div>
                                    <div style="color:rgba(255,255,255,0.4);font-size:12px">@s.Email</div>
                                </td>
                                <td style="color:#4f8ef7;font-weight:600">@s.StudentNumber</td>
                                <td>@(string.IsNullOrEmpty(s.Program) ? "—" : s.Program)</td>
                                <td>@s.RegisteredAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <span class="badge @(s.Status == "Enrolled" ? "badge-enrolled" : s.Status == "Rejected" ? "badge-rejected" : "badge-pending")">
                                        @s.Status
                                    </span>
                                </td>
                                <td>
                                    <div class="action-cell">
                                        <a href="/Admin/StudentDetails/@s.Id" class="btn-sm btn-view">View</a>
                                        @if (s.Status == "Pending")
                                        {
                                            <form method="post" action="/Admin/UpdateStatus" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="studentId" value="@s.Id" />
                                                <input type="hidden" name="status" value="Enrolled" />
                                                <button type="submit" class="btn-sm btn-approve">✓ Approve</button>
                                            </form>
                                            <form method="post" action="/Admin/UpdateStatus" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="studentId" value="@s.Id" />
                                                <input type="hidden" name="status" value="Rejected" />
                                                <button type="submit" class="btn-sm btn-reject">✗ Reject</button>
                                            </form>
                                        }
                                        <form method="post" action="/Admin/DeleteStudent" style="display:inline"
                                            onsubmit="return confirm('Are you sure you want to permanently delete @(s.FirstName) @(s.LastName)\'s account? This cannot be undone.')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="studentId" value="@s.Id" />
                                            <button type="submit" class="btn-sm btn-delete">🗑 Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <!-- PAYMENTS TAB -->
        <div id="tab-payments" class="tab-panel">
            <div class="table-header"><h3>Payment Records</h3></div>
            @if (!payments.Any())
            {
                <div class="no-data">No payment records found.</div>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Student</th><th>Tuition Fee</th><th>Misc Fee</th><th>Total</th>
                            <th>Date Created</th><th>Paid On</th><th>Status</th><th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in payments)
                        {
                            var student = Model.FirstOrDefault(s => s.Id == p.StudentId);
                            <tr>
                                <td>
                                    <div style="font-weight:600;color:#fff">@(student != null ? student.FirstName + " " + student.LastName : "Unknown")</div>
                                    <div style="color:rgba(255,255,255,0.4);font-size:12px">@(student?.StudentNumber ?? "")</div>
                                </td>
                                <td>₱@p.TuitionFee.ToString("N2")</td>
                                <td>₱@p.MiscFee.ToString("N2")</td>
                                <td style="color:#fff;font-weight:700">₱@p.TotalFee.ToString("N2")</td>
                                <td>@p.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>@(p.PaidAt.HasValue ? p.PaidAt.Value.ToString("MMM dd, yyyy") : "—")</td>
                                <td>
                                    <span class="badge @(p.Status == "Paid" ? "badge-paid" : "badge-unpaid")">@p.Status</span>
                                </td>
                                <td>
                                    @if (p.Status == "Unpaid")
                                    {
                                        <form method="post" action="/Admin/MarkAsPaid">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="paymentId" value="@p.Id" />
                                            <button type="submit" class="btn-sm btn-paid">✓ Mark as Paid</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="already-paid">✓ Settled</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <!-- COURSES TAB -->
        <div id="tab-courses" class="tab-panel">
            <div class="table-header">
                <h3>Programs / Courses</h3>
                <button class="btn-primary" onclick="document.getElementById('addCourseModal').classList.add('open')">+ Add Course</button>
            </div>
            @if (!courses.Any())
            {
                <div class="no-data">No courses yet.</div>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Course Name</th><th>Department</th><th>Units</th>
                            <th>Slots</th><th>Enrolled</th><th>Status</th><th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in courses)
                        {
                            <tr>
                                <td style="font-weight:600;color:#fff">@c.Name</td>
                                <td>@c.Department</td>
                                <td>@c.Units</td>
                                <td>@c.Slots</td>
                                <td>@c.EnrolledCount / @c.Slots</td>
                                <td>
                                    <span class="badge @(c.IsActive ? "badge-active" : "badge-inactive")">
                                        @(c.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <button class="btn-sm btn-edit"
                                        onclick="openEditModal(@c.Id, '@c.Name.Replace("'","\\'")', '@c.Department.Replace("'","\\'")', @c.Units, @c.Slots)">
                                        Edit
                                    </button>
                                    <form method="post" action="/Admin/ToggleCourse" style="display:inline;margin-left:6px">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@c.Id" />
                                        <button type="submit" class="btn-sm @(c.IsActive ? "btn-toggle-on" : "btn-toggle-off")">
                                            @(c.IsActive ? "Deactivate" : "Activate")
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <!-- Add Course Modal -->
    <div class="modal-overlay" id="addCourseModal">
        <div class="modal-box">
            <h3>➕ Add New Course</h3>
            <form method="post" action="/Admin/AddCourse">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label>Course Name</label>
                    <input type="text" name="name" class="form-input" placeholder="e.g. Bachelor of Science in IT" required />
                </div>
                <div class="form-group">
                    <label>Department</label>
                    <input type="text" name="department" class="form-input" placeholder="e.g. College of Computing" required />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Units</label>
                        <input type="number" name="units" class="form-input" placeholder="e.g. 180" required />
                    </div>
                    <div class="form-group">
                        <label>Slots</label>
                        <input type="number" name="slots" class="form-input" placeholder="e.g. 50" required />
                    </div>
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn-cancel" onclick="document.getElementById('addCourseModal').classList.remove('open')">Cancel</button>
                    <button type="submit" class="btn-primary">Add Course</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Course Modal -->
    <div class="modal-overlay" id="editCourseModal">
        <div class="modal-box">
            <h3>✏️ Edit Course</h3>
            <form method="post" action="/Admin/EditCourse">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editCourseId" />
                <div class="form-group">
                    <label>Course Name</label>
                    <input type="text" name="name" id="editCourseName" class="form-input" required />
                </div>
                <div class="form-group">
                    <label>Department</label>
                    <input type="text" name="department" id="editCourseDept" class="form-input" required />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Units</label>
                        <input type="number" name="units" id="editCourseUnits" class="form-input" required />
                    </div>
                    <div class="form-group">
                        <label>Slots</label>
                        <input type="number" name="slots" id="editCourseSlots" class="form-input" required />
                    </div>
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn-cancel" onclick="document.getElementById('editCourseModal').classList.remove('open')">Cancel</button>
                    <button type="submit" class="btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function switchTab(name, btn) {
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('tab-' + name).classList.add('active');
            btn.classList.add('active');
        }
        function openEditModal(id, name, dept, units, slots) {
            document.getElementById('editCourseId').value = id;
            document.getElementById('editCourseName').value = name;
            document.getElementById('editCourseDept').value = dept;
            document.getElementById('editCourseUnits').value = units;
            document.getElementById('editCourseSlots').value = slots;
            document.getElementById('editCourseModal').classList.add('open');
        }
    </script>
</body>
</html>