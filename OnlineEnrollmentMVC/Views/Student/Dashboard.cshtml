@model OnlineEnrollmentMVC.Models.Student
@{
    ViewData["Title"] = "Student Dashboard";
    Layout = null;
    var enrollment = ViewBag.Enrollment as OnlineEnrollmentMVC.Models.Enrollment;
    var payment = ViewBag.Payment as OnlineEnrollmentMVC.Models.Payment;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Online Enrollment - Dashboard</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #0a0e2e 0%, #1a1f4e 50%, #0d1537 100%);
            font-family: 'Segoe UI', sans-serif;
        }
        .top-bar {
            display: flex; justify-content: space-between; align-items: center;
            padding: 16px 32px; background: rgba(255,255,255,0.05);
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .top-left { display: flex; align-items: center; gap: 10px; }
        .logo-icon { font-size: 24px; }
        .logo-text { color: #fff; font-size: 18px; font-weight: 700; }
        .top-right { display: flex; align-items: center; gap: 12px; }
        .student-name { color: #fff; font-size: 13px; font-weight: 600; }
        .btn-nav {
            padding: 8px 16px; background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15); border-radius: 8px;
            color: rgba(255,255,255,0.7); font-size: 13px; text-decoration: none;
        }
        .btn-logout {
            padding: 8px 16px; background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.2); border-radius: 8px;
            color: #fca5a5; font-size: 13px; text-decoration: none;
        }
        .content { padding: 32px; }
        .welcome { margin-bottom: 32px; }
        .welcome h2 { color: #fff; font-size: 26px; font-weight: 700; margin-bottom: 6px; }
        .welcome p { color: rgba(255,255,255,0.5); font-size: 14px; }
        .student-num { color: #4f8ef7; font-weight: 600; }
        .cards-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-bottom: 32px; }
        .card {
            background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px; padding: 24px;
        }
        .card h3 { color: rgba(255,255,255,0.9); font-size: 14px; font-weight: 700;
            margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid rgba(255,255,255,0.07); }
        .info-row { display: flex; justify-content: space-between; padding: 9px 0;
            border-bottom: 1px solid rgba(255,255,255,0.04); }
        .info-label { color: rgba(255,255,255,0.4); font-size: 13px; }
        .info-value { color: rgba(255,255,255,0.8); font-size: 13px; font-weight: 500; }
        .badge { padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
        .badge-pending { background: rgba(251,191,36,0.15); color: #fbbf24; }
        .badge-enrolled { background: rgba(34,197,94,0.15); color: #4ade80; }
        .badge-rejected { background: rgba(239,68,68,0.15); color: #fca5a5; }
        .badge-paid { background: rgba(34,197,94,0.15); color: #4ade80; }
        .badge-unpaid { background: rgba(251,191,36,0.15); color: #fbbf24; }
        .no-data { color: rgba(255,255,255,0.3); font-size: 13px; padding: 12px 0; }
        .action-links { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 8px; }
        .btn-action {
            padding: 10px 20px; background: linear-gradient(135deg, #4f8ef7, #2563eb);
            border: none; border-radius: 10px; color: #fff; font-size: 13px;
            font-weight: 600; text-decoration: none; display: inline-block;
        }
        .btn-action-outline {
            padding: 10px 20px; background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.15); border-radius: 10px;
            color: rgba(255,255,255,0.7); font-size: 13px; text-decoration: none; display: inline-block;
        }
        .fee-total { color: #fff; font-size: 20px; font-weight: 700; margin-top: 8px; }
    </style>
</head>
<body>
    <div class="top-bar">
        <div class="top-left">
            <span class="logo-icon">🎓</span>
            <span class="logo-text">Online Enrollment</span>
        </div>
        <div class="top-right">
            <span class="student-name">@Model.FirstName @Model.LastName</span>
            <a href="/Student/Subjects" class="btn-nav">My Subjects</a>
            <a href="/Student/EditProfile" class="btn-nav">Edit Profile</a>
            <a href="/Account/Logout" class="btn-logout">Logout</a>
        </div>
    </div>

    <div class="content">
        <div class="welcome">
            <h2>Welcome back, @Model.FirstName! 👋</h2>
            <p>Student No: <span class="student-num">@Model.StudentNumber</span> &nbsp;|&nbsp;
               Status: <span class="badge @(Model.Status == "Enrolled" ? "badge-enrolled" : Model.Status == "Rejected" ? "badge-rejected" : "badge-pending")">@Model.Status</span>
            </p>
        </div>

        <div class="cards-grid">
            <!-- Personal Info -->
            <div class="card">
                <h3>👤 Personal Information</h3>
                <div class="info-row">
                    <span class="info-label">Full Name</span>
                    <span class="info-value">@Model.FirstName @Model.LastName</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Email</span>
                    <span class="info-value">@Model.Email</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Phone</span>
                    <span class="info-value">@(string.IsNullOrEmpty(Model.Phone) ? "—" : Model.Phone)</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Address</span>
                    <span class="info-value">@(string.IsNullOrEmpty(Model.Address) ? "—" : Model.Address)</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Birth Date</span>
                    <span class="info-value">@Model.BirthDate.ToString("MMMM dd, yyyy")</span>
                </div>
            </div>

            <!-- Enrollment Info -->
            <div class="card">
                <h3>📚 Enrollment</h3>
                @if (enrollment == null)
                {
                    <p class="no-data">You have not enrolled in a program yet.</p>
                    <div class="action-links" style="margin-top:16px">
                        <a href="/Courses/Index?studentId=@Model.Id" class="btn-action">Browse Programs</a>
                    </div>
                }
                else
                {
                    <div class="info-row">
                        <span class="info-label">Program</span>
                        <span class="info-value">@enrollment.Course.Name</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Department</span>
                        <span class="info-value">@enrollment.Course.Department</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Units</span>
                        <span class="info-value">@enrollment.Course.Units units</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Enrolled On</span>
                        <span class="info-value">@enrollment.EnrolledAt.ToString("MMM dd, yyyy")</span>
                    </div>
                    <div class="action-links" style="margin-top:16px">
                        <a href="/Student/Subjects" class="btn-action">View Subjects</a>
                        <a href="/Courses/Index?studentId=@Model.Id" class="btn-action-outline">Change Program</a>
                    </div>
                }
            </div>

            <!-- Payment Info -->
            <div class="card">
                <h3>💳 Payment</h3>
                @if (payment == null)
                {
                    <p class="no-data">No payment record found.</p>
                }
                else
                {
                    <div class="info-row">
                        <span class="info-label">Tuition Fee</span>
                        <span class="info-value">₱@payment.TuitionFee.ToString("N2")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Misc Fee</span>
                        <span class="info-value">₱@payment.MiscFee.ToString("N2")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Total</span>
                        <span class="info-value fee-total">₱@payment.TotalFee.ToString("N2")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Status</span>
                        <span class="badge @(payment.Status == "Paid" ? "badge-paid" : "badge-unpaid")">@payment.Status</span>
                    </div>
                    @if (payment.PaidAt.HasValue)
                    {
                        <div class="info-row">
                            <span class="info-label">Paid On</span>
                            <span class="info-value">@payment.PaidAt.Value.ToString("MMM dd, yyyy")</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</body>
</html>
