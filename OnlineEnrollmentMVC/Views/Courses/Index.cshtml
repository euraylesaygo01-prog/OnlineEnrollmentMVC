@model List<OnlineEnrollmentMVC.Models.Course>
@{
    ViewData["Title"] = "Select Program";
    Layout = null;
    var student = ViewBag.Student as OnlineEnrollmentMVC.Models.Student;
    var studentId = (int)ViewBag.StudentId;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Online Enrollment - Select Program</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #0a0e2e 0%, #1a1f4e 50%, #0d1537 100%);
            font-family: 'Segoe UI', sans-serif;
        }
        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 32px;
            background: rgba(255,255,255,0.05);
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .top-left { display: flex; align-items: center; gap: 10px; }
        .logo-icon { font-size: 24px; }
        .logo-text { color: #fff; font-size: 18px; font-weight: 700; }
        .student-info { display: flex; flex-direction: column; align-items: flex-end; color: rgba(255,255,255,0.7); font-size: 13px; }
        .student-num { color: #4f8ef7; font-weight: 600; }
        .content { padding: 32px; }
        .page-header { margin-bottom: 24px; }
        .page-header h2 { color: #fff; font-size: 26px; font-weight: 700; margin-bottom: 6px; }
        .page-header p { color: rgba(255,255,255,0.5); font-size: 14px; }
        .filter-bar { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 24px; }
        .filter-btn {
            padding: 8px 18px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 20px;
            color: rgba(255,255,255,0.7);
            font-size: 13px;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s;
        }
        .filter-btn.active, .filter-btn:hover {
            background: #2563eb;
            border-color: #2563eb;
            color: #fff;
        }
        .main-layout { display: flex; gap: 24px; align-items: flex-start; }
        .courses-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 16px;
            flex: 1;
        }
        .course-card {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            padding: 20px;
            cursor: pointer;
            transition: all 0.3s;
            position: relative;
        }
        .course-card:hover { background: rgba(255,255,255,0.08); border-color: #4f8ef7; }
        .course-dept { color: #4f8ef7; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
        .course-name { color: #fff; font-size: 15px; font-weight: 600; margin-bottom: 12px; }
        .course-footer { display: flex; gap: 12px; color: rgba(255,255,255,0.4); font-size: 12px; }
        .view-btn {
            display: block;
            margin-top: 12px;
            padding: 6px 12px;
            background: rgba(79,142,247,0.15);
            border: 1px solid rgba(79,142,247,0.3);
            border-radius: 8px;
            color: #4f8ef7;
            font-size: 12px;
            text-align: center;
            text-decoration: none;
        }
        .subjects-panel {
            width: 400px;
            flex-shrink: 0;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 20px;
            padding: 24px;
            position: sticky;
            top: 20px;
            max-height: calc(100vh - 120px);
            overflow-y: auto;
            display: none;
        }
        .subjects-panel.active { display: block; }
        .panel-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; }
        .panel-header h3 { color: #fff; font-size: 16px; font-weight: 700; margin-bottom: 4px; }
        .panel-header p { color: #4f8ef7; font-size: 12px; }
        .btn-close {
            background: rgba(255,255,255,0.08);
            border: none;
            color: rgba(255,255,255,0.5);
            width: 28px;
            height: 28px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 12px;
        }
        .year-tabs { display: flex; gap: 6px; margin-bottom: 10px; flex-wrap: wrap; }
        .year-btn {
            padding: 6px 14px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: rgba(255,255,255,0.6);
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .year-btn.active { background: #2563eb; border-color: #2563eb; color: #fff; }
        .sem-tabs { display: flex; gap: 6px; margin-bottom: 16px; }
        .sem-btn {
            flex: 1;
            padding: 7px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: rgba(255,255,255,0.6);
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .sem-btn.active { background: rgba(79,142,247,0.2); border-color: #4f8ef7; color: #4f8ef7; }
        .subject-section-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; padding: 8px 0 6px; margin-top: 8px; }
        .major-title { color: #60a5fa; }
        .minor-title { color: #4ade80; }
        .subject-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 12px;
            border-radius: 8px;
            margin-bottom: 6px;
            font-size: 13px;
        }
        .subject-item.major { background: rgba(96,165,250,0.08); border: 1px solid rgba(96,165,250,0.15); }
        .subject-item.minor { background: rgba(74,222,128,0.06); border: 1px solid rgba(74,222,128,0.12); }
        .sub-name { color: rgba(255,255,255,0.85); }
        .sub-units { color: rgba(255,255,255,0.4); font-size: 12px; }
        .total-units-bar { text-align: right; color: rgba(255,255,255,0.4); font-size: 12px; margin-top: 10px; padding-top: 10px; border-top: 1px solid rgba(255,255,255,0.08); }
        .total-units-bar strong { color: #fff; }
        .btn-select-course {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #4f8ef7, #2563eb);
            border: none;
            border-radius: 10px;
            color: #fff;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 16px;
        }
        .subjects-loading { color: rgba(255,255,255,0.5); text-align: center; padding: 20px; }
    </style>
</head>
<body>
    <div class="top-bar">
        <div class="top-left">
            <span class="logo-icon">🎓</span>
            <span class="logo-text">Online Enrollment</span>
        </div>
        <div class="student-info">
            <span>@student?.FirstName @student?.LastName</span>
            <span class="student-num">@student?.StudentNumber</span>
        </div>
    </div>

    <div class="content">
        <div class="page-header">
            <h2>Select Your Program</h2>
            <p>Click a program to view its subjects, then select to enroll</p>
        </div>

        <div class="filter-bar">
            <a href="#" class="filter-btn active" onclick="filterCourses('All', this)">All</a>
            <a href="#" class="filter-btn" onclick="filterCourses('Business', this)">Business</a>
            <a href="#" class="filter-btn" onclick="filterCourses('STEM', this)">STEM</a>
            <a href="#" class="filter-btn" onclick="filterCourses('Social Sciences', this)">Social Sciences</a>
            <a href="#" class="filter-btn" onclick="filterCourses('Education', this)">Education</a>
            <a href="#" class="filter-btn" onclick="filterCourses('General Education', this)">General Education</a>
        </div>

        <div class="main-layout">
            <div class="courses-grid" id="coursesGrid">
                @foreach (var course in Model)
                {
                    <div class="course-card" data-dept="@course.Department" onclick="viewSubjects(@course.Id, '@course.Name', '@course.Department')">
                        <div class="course-dept">@course.Department</div>
                        <div class="course-name">@course.Name</div>
                        <div class="course-footer">
                            <span>@course.Units units</span>
                            <span>@course.Slots slots</span>
                        </div>
                        <span class="view-btn">📋 View Subjects</span>
                    </div>
                }
            </div>

            <div class="subjects-panel" id="subjectsPanel">
                <div class="panel-header">
                    <div>
                        <h3 id="panelCourseName"></h3>
                        <p id="panelCourseDept"></p>
                    </div>
                    <button class="btn-close" onclick="closePanel()">✕</button>
                </div>

                <div class="year-tabs">
                    <button class="year-btn active" onclick="changeYear(1, this)">Year 1</button>
                    <button class="year-btn" onclick="changeYear(2, this)">Year 2</button>
                    <button class="year-btn" onclick="changeYear(3, this)">Year 3</button>
                    <button class="year-btn" onclick="changeYear(4, this)">Year 4</button>
                </div>

                <div class="sem-tabs">
                    <button class="sem-btn active" onclick="changeSem(1, this)">1st Semester</button>
                    <button class="sem-btn" onclick="changeSem(2, this)">2nd Semester</button>
                </div>

                <div id="subjectsList"></div>

                <form method="post" action="/Courses/Enroll" id="enrollForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="studentId" value="@studentId" />
                    <input type="hidden" name="courseId" id="selectedCourseId" value="" />
                    <button type="submit" class="btn-select-course">Select This Program</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        let currentCourseId = 0;
        let currentYear = 1;
        let currentSem = 1;

        function filterCourses(dept, btn) {
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            document.querySelectorAll('.course-card').forEach(card => {
                card.style.display = (dept === 'All' || card.dataset.dept === dept) ? 'block' : 'none';
            });
        }

        function viewSubjects(courseId, name, dept) {
            currentCourseId = courseId;
            currentYear = 1;
            currentSem = 1;
            document.getElementById('panelCourseName').textContent = name;
            document.getElementById('panelCourseDept').textContent = dept;
            document.getElementById('selectedCourseId').value = courseId;
            document.getElementById('subjectsPanel').classList.add('active');
            document.querySelectorAll('.year-btn').forEach((b, i) => b.classList.toggle('active', i === 0));
            document.querySelectorAll('.sem-btn').forEach((b, i) => b.classList.toggle('active', i === 0));
            loadSubjects();
        }

        function closePanel() {
            document.getElementById('subjectsPanel').classList.remove('active');
        }

        function changeYear(year, btn) {
            currentYear = year;
            document.querySelectorAll('.year-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            loadSubjects();
        }

        function changeSem(sem, btn) {
            currentSem = sem;
            document.querySelectorAll('.sem-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            loadSubjects();
        }

        async function loadSubjects() {
            const list = document.getElementById('subjectsList');
            list.innerHTML = '<p class="subjects-loading">Loading subjects...</p>';

            const response = await fetch(`/Courses/Subjects?courseId=${currentCourseId}&year=${currentYear}&semester=${currentSem}`);
            const data = await response.json();

            let html = '';

            if (data.major.length > 0) {
                html += '<div class="subject-section-title major-title">📘 Major Subjects</div>';
                data.major.forEach(s => {
                    html += `<div class="subject-item major"><span class="sub-name">${s.name}</span><span class="sub-units">${s.units} units</span></div>`;
                });
            }

            if (data.minor.length > 0) {
                html += '<div class="subject-section-title minor-title">📗 Minor Subjects</div>';
                data.minor.forEach(s => {
                    html += `<div class="subject-item minor"><span class="sub-name">${s.name}</span><span class="sub-units">${s.units} units</span></div>`;
                });
            }

            const total = (data.major.length + data.minor.length) * 3;
            html += `<div class="total-units-bar">Total: <strong>${total} units</strong> this semester</div>`;

            list.innerHTML = html;
        }
    </script>
</body>
</html>